# Local .terraform directories
**/.terraform/*

# .tfstate files (state must live in TFC, never in git)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files likely to contain secrets — never commit
*.tfvars
*.tfvars.json
!example.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config / lock can be committed for modules; keep plan artifacts out
*.tfplan

# Local env file for the docker-compose toolchain (TFC token, Proxmox creds)
.env

# macOS
.DS_Store
